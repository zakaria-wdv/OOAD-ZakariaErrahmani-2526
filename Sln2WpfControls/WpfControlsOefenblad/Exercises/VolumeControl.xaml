<Page x:Class="WpfControlsOefenblad.Exercises.VolumeControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="VolumeControl">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" />
        <Border Background="White" Grid.Row="1">
            <!-- HIERONDER BEGINT XAML VAN DE OEFENING -->
            <StackPanel Margin="40,30,40,30" x:Name="stpVolumeControl" MaxWidth="500">
                <TextBlock x:Name="txtVolume" FontSize="20" FontWeight="SemiBold" Text="Volume: 40%" Margin="0,10"/>
                <Slider x:Name="sldVolume" Minimum="0" Maximum="100" TickFrequency="5" SmallChange="5" LargeChange="5" Value="40" Margin="0,10"/>
                <Border x:Name="bdrVolume" Height="20" Background="Orange" Width="200" HorizontalAlignment="Left" CornerRadius="5" Margin="0,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
