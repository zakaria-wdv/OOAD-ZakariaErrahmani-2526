<Page x:Class="WpfControlsOefenblad.Exercises.Welkom"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BasicTextBox">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" />
        <Border Background="White" Grid.Row="1">
            <!-- HIERONDER BEGINT XAML VAN DE OEFENING -->
            <Grid MaxWidth="400" Margin="20" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label x:Name="lblNaam" Grid.Row="0" Grid.Column="0" Content="Naam:" Margin="0,0,0,10" Padding="0"/>
                <TextBox x:Name="txtNaam" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" Padding="400" Height="40"/>
                <Button x:Name="btnZegHallo" Grid.Row="1" Grid.Column="1" Content="Zeg Hallo" Padding="10" Height="40" Click="btnZegHallo_Click"/>
                <TextBlock x:Name="txtFout" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="gelieve een naam in te vullen" Margin="0,8,0,0" Foreground="#900" FontStyle="Italic" Visibility="Hidden"/>
                <TextBlock x:Name="txtWelkom" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="..." Margin="0,20,0,0" FontSize="16" FontWeight="SemiBold"/>
            </Grid>

        </Border>
    </Grid>
</Page>
