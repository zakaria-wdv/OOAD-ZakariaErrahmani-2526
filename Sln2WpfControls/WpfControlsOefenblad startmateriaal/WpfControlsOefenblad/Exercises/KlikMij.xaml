<Page x:Class="WpfControlsOefenblad.Exercises.KlikMij"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfControlsOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="KlikMij">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" />
        <Border Background="White" Grid.Row="1">
            <!-- HIERONDER BEGINT XAML VAN DE OEFENING -->
            <StackPanel Margin="20">
                <Button Content="Klik mij" Margin="10" Padding="5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                <TextBlock Margin="10" Text="..." HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
