<Page x:Class="WpfBestandenOefenblad.Exercises.PadBuilder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfBestandenOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PadBuilder">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="280"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" />
        <Border Background="White" Grid.Row="1">
            <!-- XAML VAN DE OEFENING -->
            <Grid Margin="20" Background="AliceBlue" MaxWidth="600">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Speciale map:" Grid.Row="0" Grid.Column="0" Margin="10" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10">
                    <RadioButton x:Name="rdbDocumenten" Content="Documenten" Margin="0,0,20,0" GroupName="Map" IsChecked="True"/>
                    <RadioButton x:Name="rdbAfbeeldingen" Content="Afbeeldingen" Margin="0,0,20,0" GroupName="Map"/>
                    <RadioButton x:Name="rdbDesktop" Content="Desktop" GroupName="Map"/>
                </StackPanel>

                <TextBlock Text="Pad:" Grid.Row="1" Grid.Column="0" Margin="10" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPad" Grid.Row="1" Grid.Column="1" Margin="10" Padding="4,2" Text="Test/Bestanden/"/>

                <TextBlock Text="Bestandsnaam:" Grid.Row="2" Grid.Column="0" Margin="10" VerticalAlignment="Center"/>
                <TextBox x:Name="txtBestandsnaam" Grid.Row="2" Grid.Column="1" Margin="10" Padding="4,2" Text="randombestand.aspx"/>

                <Button x:Name="btnGenereerPad" Content="Genereer pad" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                        Padding="8,4" HorizontalAlignment="Left" Margin="10" />

                <TextBlock x:Name="txtResultaat" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap" FontFamily="Consolas" Margin="10"/>
            </Grid>
        </Border>
    </Grid>
</Page>
